{% set cta_name = page.header.cta|default("default") %}

{#
  CTA authoring contract:
  - Omit `cta` in frontmatter to render the default CTA.
  - Set `cta: none` to suppress the CTA for a specific post.
  - Set `cta: some-name` to render `partials/blog/ctas/some-name.md.twig`
    or `partials/blog/ctas/some-name.html.twig`.
#}
{% if cta_name != "none" %}
    {% set markdown_templates = [
        "partials/blog/ctas/" ~ cta_name ~ ".md.twig",
        "partials/blog/ctas/default.md.twig",
    ] %}
    {% set html_templates = [
        "partials/blog/ctas/" ~ cta_name ~ ".html.twig",
        "partials/blog/ctas/default.html.twig",
    ] %}

    {% set markdown_cta %}
        {% include markdown_templates ignore missing %}
    {% endset %}

    {% if markdown_cta|trim %}
        {{ markdown_cta|markdown }}
    {% else %}
        {% include html_templates ignore missing %}
    {% endif %}
{% endif %}
